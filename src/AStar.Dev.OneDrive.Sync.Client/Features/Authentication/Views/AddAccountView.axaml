<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AStar.Dev.OneDrive.Sync.Client.Features.Authentication.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="AStar.Dev.OneDrive.Sync.Client.Features.Authentication.Views.AddAccountView"
             x:DataType="vm:AddAccountViewModel">
  
  <Design.DataContext>
    <vm:AddAccountViewModel/>
  </Design.DataContext>

  <StackPanel Margin="20" Spacing="15">
    
    <!-- Title -->
    <TextBlock Text="Add Microsoft OneDrive Account" 
               FontSize="20" 
               FontWeight="Bold" 
               HorizontalAlignment="Center"/>
    
    <!-- Instructions -->
    <TextBlock TextWrapping="Wrap"
               HorizontalAlignment="Center"
               Margin="0,10,0,20">
      Click the button below to authenticate with your Microsoft account.
      You will be prompted to sign in through your default web browser.
    </TextBlock>
    
    <!-- Status Message -->
    <TextBlock Text="{Binding StatusMessage}" 
               FontSize="14"
               TextWrapping="Wrap"
               HorizontalAlignment="Center"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    
    <!-- Error Message -->
    <Border Background="#FFEEEE" 
            CornerRadius="5" 
            Padding="10"
            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding ErrorMessage}" 
                 Foreground="Red"
                 FontSize="14"
                 TextWrapping="Wrap"/>
    </Border>
    
    <!-- Authenticate Button -->
    <Button Content="Authenticate with Microsoft"
            Command="{Binding AuthenticateCommand}"
            HorizontalAlignment="Center"
            Padding="20,10"
            FontSize="14"
            IsEnabled="{Binding !IsAuthenticating}"/>
    
    <!-- Progress Indicator -->
    <StackPanel Orientation="Horizontal" 
                HorizontalAlignment="Center" 
                Spacing="10"
                IsVisible="{Binding IsAuthenticating}">
      <TextBlock Text="⏳ Authenticating..." FontSize="14"/>
    </StackPanel>
    
    <StackPanel Orientation="Horizontal" 
                HorizontalAlignment="Center" 
                Spacing="10"
                IsVisible="{Binding IsCreatingAccount}">
      <TextBlock Text="⏳ Creating account..." FontSize="14"/>
    </StackPanel>
    
    <!-- Success Message -->
    <Border Background="#EEFFEE" 
            CornerRadius="5" 
            Padding="10"
            IsVisible="{Binding CreatedAccount, Converter={x:Static ObjectConverters.IsNotNull}}">
      <StackPanel Spacing="5">
        <TextBlock Text="✓ Account created successfully!" 
                   Foreground="Green"
                   FontSize="16"
                   FontWeight="Bold"/>
        <TextBlock Text="{Binding CreatedAccount.HashedEmail, StringFormat='Email: {0}'}" 
                   FontSize="12"/>
      </StackPanel>
    </Border>
    
  </StackPanel>
  
</UserControl>
