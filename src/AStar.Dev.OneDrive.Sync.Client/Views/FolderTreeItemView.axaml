<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AStar.Dev.OneDrive.Sync.Client.ViewModels"
             xmlns:controls="clr-namespace:AStar.Dev.OneDrive.Sync.Client.Controls"
             x:Class="AStar.Dev.OneDrive.Sync.Client.Controls.FolderTreeItemView"
             x:DataType="vm:FolderTreeNodeViewModel">

    <StackPanel>

        <!-- Folder row -->
        <Border Background="Transparent" Padding="0,1">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">

                <!-- Indentation -->
                <Border Grid.Column="0"
                        Width="{Binding Depth,
                            Converter={StaticResource DepthToIndentConverter}}"/>

                <!-- Expander — visible when has children -->
                <Button Grid.Column="1"
                        Width="24" Height="24"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        IsVisible="{Binding HasChildren}"
                        Command="{Binding ToggleExpandCommand}">
                    <TextBlock Text="{Binding ExpanderGlyph}"
                               FontSize="{StaticResource FontSizeXs}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Spacer when leaf node -->
                <Border Grid.Column="1"
                        Width="24"
                        IsVisible="{Binding !HasChildren}"/>

                <!-- Folder icon -->
                <Viewbox Grid.Column="2"
                         Width="16" Height="16"
                         Margin="0,0,6,0"
                         VerticalAlignment="Center">
                    <Canvas Width="24" Height="24">
                        <Path Fill="{DynamicResource TextSecondaryBrush}"
                              Data="M10,4 H4 C2.9,4 2,4.9 2,6 V18 C2,19.1 2.9,20 4,20
                                    H20 C21.1,20 22,19.1 22,18 V8 C22,6.9 21.1,6 20,6
                                    H12 L10,4 Z"/>
                    </Canvas>
                </Viewbox>

                <!-- Folder name -->
                <TextBlock Grid.Column="3"
                           Text="{Binding Name}"
                           FontSize="{StaticResource FontSizeMd}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Status badge -->
                <Border Grid.Column="4"
                        Margin="8,0"
                        Padding="6,2"
                        CornerRadius="{StaticResource RadiusSm}"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding SyncState,
                            Converter={StaticResource SyncStateToBadgeBackgroundConverter}}"/>
                    </Border.Background>
                    <TextBlock Text="{Binding StatusBadgeText}"
                               FontSize="{StaticResource FontSizeXs}"
                               VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{Binding SyncState,
                                Converter={StaticResource SyncStateToBadgeForegroundConverter}}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Border>

                <!-- Include / exclude toggle -->
                <Button Grid.Column="5"
                        Padding="6,3"
                        Margin="0,0,4,0"
                        CornerRadius="{StaticResource RadiusSm}"
                        Background="Transparent"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1"
                        Command="{Binding ToggleIncludeCommand}"
                        ToolTip.Tip="{Binding IsIncluded,
                            Converter={StaticResource BoolToExcludeIncludeTooltipConverter}}">
                    <TextBlock Text="{Binding IsIncluded,
                                   Converter={StaticResource BoolToExcludeIncludeLabelConverter}}"
                               FontSize="{StaticResource FontSizeXs}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>

                <!-- Action buttons -->
                <StackPanel Grid.Column="6"
                            Orientation="Horizontal"
                            Spacing="4">

                    <Button Padding="4"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding OpenInFileManagerCommand}"
                            ToolTip.Tip="Open in file manager">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource TextTertiaryBrush}"
                                      StrokeThickness="2"
                                      Fill="Transparent"
                                      Data="M3,12 L3,19 C3,20.1 3.9,21 5,21 H19
                                            C20.1,21 21,20.1 21,19 V12
                                            M12,3 L12,15 M8,7 L12,3 L16,7"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button Padding="4"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding ViewActivityCommand}"
                            ToolTip.Tip="View folder activity">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource TextTertiaryBrush}"
                                      StrokeThickness="2"
                                      Fill="Transparent"
                                      Data="M3,3 H21 M3,9 H15 M3,15 H18 M3,21 H12"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>

        <!-- Loading children indicator -->
        <ProgressBar IsVisible="{Binding IsLoadingChildren}"
                     IsIndeterminate="True"
                     Height="2"
                     Margin="24,0,0,0"
                     Foreground="{DynamicResource TextAccentBrush}"
                     Background="Transparent"/>

        <!-- Recursive children -->
        <ItemsControl IsVisible="{Binding IsExpanded}"
                      ItemsSource="{Binding Children}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:FolderTreeNodeViewModel">
                    <controls:FolderTreeItemView/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>

</UserControl>
